# Configuración de desarrollo local
# Renombrar este archivo a .env en desarrollo

PORT=3000
NODE_ENV=development

# HubSpot OAuth Configuration
CLIENT_ID=16364eec-31a5-4421-9c58-e9d0f2868797
CLIENT_SECRET=0da5a703-ef03-4d69-b4dd-62d5e7a59042
SCOPE=crm.lists.write crm.objects.companies.read crm.objects.companies.write crm.objects.contacts.read crm.objects.contacts.write crm.objects.deals.read crm.objects.deals.write crm.objects.owners.read crm.schemas.companies.read crm.schemas.contacts.read crm.schemas.deals.read files forms oauth tickets conversations.custom_channels.read conversations.custom_channels.write

# URLs de desarrollo (usa ngrok para webhooks)
REDIRECT_URI=http://localhost:3000/oauth-callback
WEBHOOK_BASE_URL=https://tu-ngrok-url.ngrok.io

# HubSpot Portal (fallback mono-tenant)
HUBSPOT_PORTAL_ID=49753409

# Base de datos PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/whatsapphub

# WhatsApp Provider: "evolution" o "gupshup"
WHATSAPP_PROVIDER=evolution

# --- EvolutionAPI (cuando WHATSAPP_PROVIDER=evolution) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=tu-api-key-de-evolution
EVOLUTION_INSTANCE=whatsapphub

# --- Gupshup Partner API (cuando WHATSAPP_PROVIDER=gupshup) ---
GUPSHUP_PARTNER_EMAIL=tu-email@empresa.com
GUPSHUP_PARTNER_PASSWORD=tu-password-gupshup

# WhatsApp Webhook
WHATSAPP_WEBHOOK_VERIFY_TOKEN=tu_token_secreto_aqui

# Logs
LOG_LEVEL=debug
